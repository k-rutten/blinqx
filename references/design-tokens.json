  "identity": {
    "$description": "Design rationale — WHY Blinqx looks the way it does. Read this to make decisions for edge cases and new components.",
    "product": "Financial software for mortgage advisors and homebuyers (Netherlands)",
    "tone": "Trustworthy + approachable — professional enough for financial decisions, warm enough not to intimidate first-time homebuyers",
    "principles": [
      "Professional but not corporate — navy over black, muted blue over saturated, SemiBold over Bold",
      "Friendly but not playful — pill buttons, rounded containers, but structured layouts with clear hierarchy",
      "Calm expertise — the 'trusted advisor' feeling, not aggressive sales or sterile banking",
      "Data-first — minimal chrome, bottom-border inputs, generous spacing, hierarchy through size not weight",
      "One voice — max 1 CTA per view, consistent status patterns, no mixing of more than 2 button styles"
    ],
    "decisionTest": [
      "Would a mortgage advisor show this to a client? → If too playful, dial back",
      "Would a first-time homebuyer feel comfortable? → If too corporate, warm it up",
      "Is there clear visual hierarchy? → One CTA, clear headings, calm body text"
    ]
  },

