        "info":              { "$value": "{colors.palette.blue.100}",    "$resolvedValue": "#6DA6B9" }
      }
    },

    "statusPatterns": {
      "$description": "Pre-composed color combos for status messages and chips. Copy these directly.",
      "warning":  { "bg": "#EDBCBC", "text": "#951C1C", "icon": "#951C1C", "semanticBg": "surface-badge",          "semanticText": "text-red-dark" },
      "info":     { "bg": "#EFF2F7", "text": "#316A7D", "icon": "#316A7D", "semanticBg": "surface-pull-down-menu",  "semanticText": "text-blue-dark" },
      "success":  { "bg": "#CDF0EA", "text": "#005C3E", "icon": "#005C3E", "semanticBg": "surface-green-light",     "semanticText": "text-green-dark" },
      "error":    { "bg": "#F6DEDE", "text": "#951C1C", "icon": "#D15858", "semanticBg": "surface-red-light",       "semanticText": "text-red-dark" }
    }
