        "help":              { "$value": "{colors.palette.neutral.80}",  "$resolvedValue": "#4A515B", "$description": "Secondary/help text" },
        "placeholder":       { "$value": "{colors.palette.neutral.60}",  "$resolvedValue": "#777D84", "$description": "Input placeholder" },
        "disabled-default":  { "$value": "{colors.palette.neutral.60}",  "$resolvedValue": "#777D84", "$description": "Disabled text (on colored bg)" },
        "disabled-light":    { "$value": "{colors.palette.neutral.20}",  "$resolvedValue": "#D2D4D6", "$description": "Disabled text (on white bg)" },
