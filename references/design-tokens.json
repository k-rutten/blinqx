        "blue-light":        { "$value": "{colors.palette.blue.30}",     "$resolvedValue": "#D3E4EA", "$description": "Light blue surface" },
        "yellow-default":    { "$value": "{colors.palette.yellow.100}",  "$resolvedValue": "#FFCD00", "$description": "CTA button bg" },
