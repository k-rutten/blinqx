    },
    "styles": {
      "h1":       { "size": { "$value": "45px" }, "lineHeight": { "$value": "52px" }, "weight": { "$value": 500 }, "weightName": "Medium",   "$description": "Page titles in headers" },
      "h2":       { "size": { "$value": "28px" }, "lineHeight": { "$value": "36px" }, "weight": { "$value": 600 }, "weightName": "SemiBold", "$description": "Section headings (confirmed from Figma)" },
      "h3":       { "size": { "$value": "22px" }, "lineHeight": { "$value": "28px" }, "weight": { "$value": 600 }, "weightName": "SemiBold", "$description": "Alert/modal titles, card section titles" },
      "bodyL":    { "size": { "$value": "16px" }, "lineHeight": { "$value": "24px" }, "weight": { "$value": 500 }, "weightName": "Medium",   "$description": "Body text, input values, modal body" },
      "bodyLBold":{ "size": { "$value": "16px" }, "lineHeight": { "$value": "24px" }, "weight": { "$value": 600 }, "weightName": "SemiBold", "$description": "Message bar headers" },
      "bodyM":    { "size": { "$value": "14px" }, "lineHeight": { "$value": "20px" }, "weight": { "$value": 500 }, "weightName": "Medium",   "$description": "Secondary body, radio/checkbox labels" },
      "bodyMBold":{ "size": { "$value": "14px" }, "lineHeight": { "$value": "20px" }, "weight": { "$value": 600 }, "weightName": "SemiBold", "$description": "Button labels, tab labels, card titles" },
      "bodyS":    { "size": { "$value": "12px" }, "lineHeight": { "$value": "16px" }, "weight": { "$value": 500 }, "weightName": "Medium",   "$description": "Captions, chip labels, tooltip text" },
      "bodySBold":{ "size": { "$value": "12px" }, "lineHeight": { "$value": "16px" }, "weight": { "$value": 600 }, "weightName": "SemiBold", "$description": "Menu labels, small emphasis" },
      "bodyXS":   { "size": { "$value": "10px" }, "lineHeight": { "$value": "100%" }, "weight": { "$value": 500 }, "weightName": "Medium",   "$description": "Extra small text" },
      "bodyXSBold":{ "size": { "$value": "10px" }, "lineHeight": { "$value": "100%" }, "weight": { "$value": 600 }, "weightName": "SemiBold", "$description": "Extra small emphasis" },
      "badge":    { "size": { "$value": "11px" }, "lineHeight": { "$value": "16px" }, "weight": { "$value": 500 }, "weightName": "Medium",   "$description": "Badge counts only" }
    },
    "rules": {
      "maxWeight": 600,
      "maxWeightName": "SemiBold",
      "neverUseBold": true,
      "minBodySize": "12px",
      "minBadgeSize": "11px"
    }
  },

  "spacing": {
    "$type": "dimension",
    "$description": "4px base grid. Only use multiples of 4.",
    "xs":  { "$value": "4px",  "$description": "Badge padding, compact gaps" },
    "sm":  { "$value": "8px",  "$description": "Icon-label gaps, pull-down item padding" },
    "md":  { "$value": "12px", "$description": "Menu item padding, tab top padding" },
    "lg":  { "$value": "16px", "$description": "Component padding, standard gaps, tab bottom padding" },
    "xl":  { "$value": "20px", "$description": "Logo padding, medium button h-padding" },
    "2xl": { "$value": "24px", "$description": "Header padding, card padding, modal padding, large button h-padding" },
    "3xl": { "$value": "32px", "$description": "Section spacing, sidebar bottom padding" },
    "4xl": { "$value": "40px", "$description": "Header left padding" }
  },

  "radii": {
    "$type": "dimension",
    "$description": "Border radius tokens.",
    "xs":   { "$value": "4px",    "$description": "Tooltip, small elements" },
    "sm":   { "$value": "8px",    "$description": "Segmented control items, pull-down items, message bars, note (right corners)" },
    "lg":   { "$value": "16px",   "$description": "Cards, headers, modals, panels, alerts, chapter bars" },
    "xl":   { "$value": "20px",   "$description": "Segmented control container" },
    "pill": { "$value": "48px",   "$description": "Buttons, badges, chips — signature Blinqx pill shape" },
    "full": { "$value": "9999px", "$description": "Circular badges, monograms" }
  },

  "shadows": {
    "$type": "shadow",
    "$description": "Three elevation levels. Never use generic CSS shadows.",
    "card":    { "$value": "0px 1px 2px rgba(0,0,0,0.25), 0px 3px 7px rgba(0,0,0,0.1)",  "$description": "Resting state: cards, panels" },
    "hovered": { "$value": "0px 2px 5px 1px rgba(0,0,0,0.1), 0px 1px 2px rgba(0,0,0,0.2)", "$description": "Interactive hover: tooltips, hovered cards" },
    "popup":   { "$value": "0px 1px 3px rgba(0,0,0,0.3), 0px 4px 8px 3px rgba(0,0,0,0.15)", "$description": "Overlays: modals, alerts, dropdowns, date pickers" }
  },

  "breakpoints": {
