        "yellow-light":      { "$value": "{colors.palette.yellow.20}",   "$resolvedValue": "#FDF4C8", "$description": "Yellow light surface" },
        "red-default":       { "$value": "{colors.palette.red.100}",     "$resolvedValue": "#D15858", "$description": "Error/danger button bg" },
        "red-dark":          { "$value": "{colors.palette.red.120}",     "$resolvedValue": "#951C1C" },
        "red-light":         { "$value": "{colors.palette.red.20}",      "$resolvedValue": "#F6DEDE", "$description": "Error surface, alert icon bg" },
        "green-default":     { "$value": "{colors.palette.green.100}",   "$resolvedValue": "#04B698" },
