    "generatedAt": "2026-03-19",
    "version": "3.0.0",
    "colorMode": "light-only",
    "$colorModeNote": "Blinqx has no dark mode. All tokens are light theme. If dark mode is added in future, add a 'dark' key alongside 'light' values."
