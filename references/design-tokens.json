    "$description": "Responsive breakpoints. Stack layouts below lg.",
    "sm":  { "$value": "640px",  "$description": "Mobile landscape" },
    "md":  { "$value": "768px",  "$description": "Tablet" },
    "lg":  { "$value": "1024px", "$description": "Desktop — layouts switch from stacked to split here" },
    "xl":  { "$value": "1280px", "$description": "Wide desktop" },
    "2xl": { "$value": "1400px", "$description": "WorQX viewport width" }
  },

  "motion": {
    "$type": "transition",
    "$description": "Animation and transition specs. Keep animations subtle — Blinqx is financial software, not a game.",
    "hover":       { "$value": "150ms ease", "property": "background-color, border-color, box-shadow", "$description": "All hover state changes" },
    "focus":       { "$value": "150ms ease", "property": "border-color, box-shadow", "$description": "Focus ring appearance" },
    "labelFloat":  { "$value": "150ms ease", "property": "transform, font-size, color", "$description": "Floating label animation" },
    "modalOpen":   { "$value": "200ms ease-out", "property": "opacity, transform", "$description": "Modal/alert fade-in + scale-up" },
    "modalClose":  { "$value": "150ms ease-in", "property": "opacity, transform", "$description": "Modal/alert fade-out" },
    "pageEnter":   { "$value": "300ms ease-out", "property": "opacity, transform", "$description": "Page content fade-in on navigation" },
    "tabSwitch":   { "$value": "150ms ease", "property": "border-color, color", "$description": "Tab active state transition" },
    "switchToggle":{ "$value": "200ms ease", "property": "background-color, left", "$description": "Switch thumb slide" },
    "rules": [
      "Never use bounce or spring easing — too playful for financial context",
      "Never exceed 300ms for any single transition",
      "Prefer ease-out for enter, ease-in for exit",
      "Disable motion if prefers-reduced-motion is set"
    ]
  },

