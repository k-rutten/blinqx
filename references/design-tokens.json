  "shadcnMapping": {
    "$description": "Maps Blinqx Figma tokens to shadcn/ui CSS variable names. v0 and Cursor expect these names.",
    "$usage": "Use these in globals.css :root block. Tailwind reads them as bg-background, text-primary, etc.",
    "variables": {
      "--background":             { "figmaToken": "B10",  "hex": "#F0F6F8", "tailwind": "bg-background" },
      "--foreground":             { "figmaToken": "N100", "hex": "#1D2632", "tailwind": "text-foreground" },
      "--card":                   { "figmaToken": "W100", "hex": "#FFFFFF", "tailwind": "bg-card" },
      "--card-foreground":        { "figmaToken": "N100", "hex": "#1D2632" },
      "--popover":                { "figmaToken": "W100", "hex": "#FFFFFF", "tailwind": "bg-popover" },
      "--popover-foreground":     { "figmaToken": "N100", "hex": "#1D2632" },
      "--primary":                { "figmaToken": "~Y110","hex": "#E5B73B", "tailwind": "bg-primary", "$note": "Working accent — between Y110-Y100" },
      "--primary-foreground":     { "figmaToken": "N100", "hex": "#1D2632" },
      "--secondary":              { "figmaToken": "B30",  "hex": "#D3E4EA", "tailwind": "bg-secondary" },
      "--secondary-foreground":   { "figmaToken": "N100", "hex": "#1D2632" },
      "--muted":                  { "figmaToken": "B30",  "hex": "#D3E4EA", "tailwind": "bg-muted" },
      "--muted-foreground":       { "figmaToken": "~N70", "hex": "#5F6D7A", "tailwind": "text-muted-foreground" },
      "--accent":                 { "figmaToken": "B30",  "hex": "#D3E4EA", "tailwind": "bg-accent" },
      "--accent-foreground":      { "figmaToken": "N100", "hex": "#1D2632" },
      "--destructive":            { "figmaToken": "R100", "hex": "#D15858", "tailwind": "bg-destructive" },
      "--destructive-foreground": { "figmaToken": "R100", "hex": "#D15858" },
      "--border":                 { "figmaToken": "B30",  "hex": "#D3E4EA", "tailwind": "border-border" },
      "--input":                  { "figmaToken": "B30",  "hex": "#D3E4EA", "tailwind": "border-input" },
      "--ring":                   { "figmaToken": "~B140","hex": "#1A5F5A", "tailwind": "ring-ring" }
    },
    "brandExtensions": {
      "--brand-teal":        { "figmaToken": "~B140", "hex": "#1A5F5A", "$note": "Section headings, focus ring" },
      "--brand-teal-light":  { "figmaToken": "B100",  "hex": "#6DA6B9", "$note": "Secondary buttons, progress bars" },
      "--brand-yellow":      { "figmaToken": "~Y110", "hex": "#E5B73B", "$note": "Active nav, primary buttons" },
      "--brand-yellow-light":{ "figmaToken": "~Y80",  "hex": "#F5D77A", "$note": "Hex inner glow, highlights" },
      "--brand-gold":        { "figmaToken": "~Y120", "hex": "#D4A84B", "$note": "Yellow button hover" },
      "--brand-peach":       { "hex": "#F5D5C8", "$note": "Avatar backgrounds" }
    }
  },

  "outputFormats": {
    "$description": "Format-specific token overrides. Read this FIRST to know which tokens apply to your output type.",

    "documents": {
      "$description": "Use for pptx, pdf, docx, xlsx. Overrides font to Inter, uses simplified color palette.",
      "$appliesTo": ["pptx", "pdf", "docx", "xlsx", "python-pptx", "reportlab", "python-docx"],
      "typography": {
        "fontFamily": "Inter",
        "fallback": "Arial, Helvetica, sans-serif",
        "whyInter": "Metropolis UI is the brand font but is not available in Office/PDF environments. Inter is the designated fallback.",
        "styles": {
          "slideTitle":     { "font": "Inter", "weight": 600, "weightName": "SemiBold", "sizeRange": "28-36pt" },
          "sectionHeading": { "font": "Inter", "weight": 600, "weightName": "SemiBold", "sizeRange": "20-24pt" },
          "bodyText":       { "font": "Inter", "weight": 500, "weightName": "Medium",   "sizeRange": "12-16pt" },
          "caption":        { "font": "Inter", "weight": 400, "weightName": "Regular",  "sizeRange": "10-12pt" },
          "tableHeader":    { "font": "Inter", "weight": 600, "weightName": "SemiBold", "sizeRange": "11-14pt" },
          "tableCell":      { "font": "Inter", "weight": 400, "weightName": "Regular",  "sizeRange": "10-12pt" }
        }
      },
      "colors": {
        "$description": "Simplified role-based palette for documents. 'pptxgenjs' key = hex without # prefix (legacy, still useful for raw hex).",
        "headingText":  { "hex": "#1D2632", "pptxgenjs": "1D2632", "role": "All headings and body text" },
        "bodyText":     { "hex": "#1D2632", "pptxgenjs": "1D2632", "role": "Paragraphs, bullet points" },
        "secondaryText":{ "hex": "#4A515B", "pptxgenjs": "4A515B", "role": "Captions, footnotes, metadata" },
        "accent":       { "hex": "#6DA6B9", "pptxgenjs": "6DA6B9", "role": "Borders, icons, highlights, chart elements" },
        "ctaHighlight": { "hex": "#FFCD00", "pptxgenjs": "FFCD00", "role": "Key callouts — max 1 per slide/page" },
        "tableHeaderBg":{ "hex": "#E2EDF1", "pptxgenjs": "E2EDF1", "role": "Table header rows" },
        "tableAltRow":  { "hex": "#F4F7F9", "pptxgenjs": "F4F7F9", "role": "Alternating table rows" },
        "divider":      { "hex": "#C5DBE3", "pptxgenjs": "C5DBE3", "role": "Horizontal rules, table borders" },
        "background":   { "hex": "#F4F7F9", "pptxgenjs": "F4F7F9", "role": "Page/slide background" },
        "cardBox":      { "hex": "#FFFFFF", "pptxgenjs": "FFFFFF", "role": "Content boxes on colored bg" },
        "success":      { "hex": "#04B698", "pptxgenjs": "04B698", "role": "Positive indicators" },
        "warning":      { "hex": "#FFA652", "pptxgenjs": "FFA652", "role": "Attention indicators" },
        "error":        { "hex": "#D15858", "pptxgenjs": "D15858", "role": "Negative indicators" }
      },
      "pptxgenjs": {
        "$description": "Copy-paste hex constants (without # prefix). Legacy naming; values still useful for any tool needing raw hex.",
        "colors": {
          "primary": "6DA6B9", "cta": "FFCD00", "success": "04B698", "warning": "FFA652",
          "danger": "D15858", "dark": "1D2632", "help": "4A515B", "placeholder": "777D84",
          "pageBg": "F4F7F9", "headerBg": "E2EDF1", "cardBg": "FFFFFF", "border": "C5DBE3"
        },
        "font": { "heading": "Inter", "body": "Inter" }
      },
      "chartColors": {
        "$description": "Ordered palette for charts. Template uses a teal/green gradient for multi-series data visualization.",
        "series": [
          { "hex": "#CDF0EA", "pptxgenjs": "CDF0EA", "label": "Series 1 — Light green" },
          { "hex": "#6DA6B9", "pptxgenjs": "6DA6B9", "label": "Series 2 — Teal blue" },
          { "hex": "#04B698", "pptxgenjs": "04B698", "label": "Series 3 — Green" },
          { "hex": "#005C3E", "pptxgenjs": "005C3E", "label": "Series 4 — Dark green" },
          { "hex": "#FFCD00", "pptxgenjs": "FFCD00", "label": "Series 5 — Yellow accent" },
          { "hex": "#D15858", "pptxgenjs": "D15858", "label": "Series 6 — Red (contrast)" },
          { "hex": "#316A7D", "pptxgenjs": "316A7D", "label": "Series 7 — Dark teal" },
          { "hex": "#FFA652", "pptxgenjs": "FFA652", "label": "Series 8 — Orange" }
        ],
        "rules": [
          "Default charts use teal/green gradient (series 1-4) — confirmed from official .potx template",
          "For 2-series: use #6DA6B9 + #04B698 (teal pair)",
          "For positive/negative: use green #04B698 + red #D15858",
          "Add yellow #FFCD00 only when 5+ series needed"
        ]
      },
      "tableStyle": {
        "$description": "Table formatting for documents.",
        "headerBg": { "hex": "#E2EDF1", "pptxgenjs": "E2EDF1" },
        "headerText": { "hex": "#1D2632", "pptxgenjs": "1D2632", "weight": 600 },
        "altRowBg": { "hex": "#F4F7F9", "pptxgenjs": "F4F7F9" },
        "cellText": { "hex": "#1D2632", "pptxgenjs": "1D2632", "weight": 400 },
        "borderColor": { "hex": "#C5DBE3", "pptxgenjs": "C5DBE3" },
        "borderWidth": "0.5pt",
        "cellPadding": { "top": "4pt", "right": "8pt", "bottom": "4pt", "left": "8pt" },
        "headerHeight": "32pt",
        "rowHeight": "24pt"
      },
      "logo": {
        "$description": "Logo placement in documents.",
        "position": "top-right or bottom-left of slide/page",
        "height": "24pt",
        "minClearSpace": "12pt",
        "color": "dark (#1D2632) on light backgrounds, white (#FFFFFF) on dark backgrounds",
        "asset": "assets/blinqx-logo.svg"
      },
      "icons": {
        "$description": "Icon usage in documents.",
        "style": "Outline/line style, not filled",
        "size": "16pt inline with text, 24pt standalone",
        "color": "Match text color (#1D2632) or accent (#6DA6B9)",
        "source": "Use Lucide or Heroicons (outline) as closest match to Blinqx icon set"
      },
      "slideLayouts": {
        "$description": "Standard slide compositions for pptx.",
        "titleSlide": {
          "bg": "F4F7F9",
          "titleFont": "Inter SemiBold 36pt",
          "titleColor": "1D2632",
          "subtitleFont": "Inter Medium 16pt",
          "subtitleColor": "4A515B",
          "accentBar": "6DA6B9, 4pt height, bottom of title area",
          "logoPosition": "bottom-right"
        },
        "contentSlide": {
          "bg": "F4F7F9",
          "titleFont": "Inter SemiBold 24pt",
          "titleColor": "1D2632",
          "bodyFont": "Inter Medium 14pt",
          "bodyColor": "1D2632",
          "contentArea": "white box with 16pt rounded corners and card shadow"
        },
        "sectionDivider": {
          "bg": "6DA6B9",
          "titleFont": "Inter SemiBold 36pt",
          "titleColor": "FFFFFF",
          "subtitleFont": "Inter Medium 16pt",
          "subtitleColor": "E2EDF1"
        },
        "twoColumn": {
          "bg": "F4F7F9",
          "split": "50-50 or 60-40",
          "gap": "16pt between columns"
        }
      },
      "presentationDesign": {
        "$description": "Visual design language from the official Blinqx .potx template. AI tools: follow these patterns when generating presentations.",
        "$source": "Blinqx_Template-Basic.potx (41 slides, 3 theme variants)",
        "themes": {
          "dark":   { "bg": "#000000", "bgAlt": "#1D2632", "text": "#FFFFFF", "accent": "#FFCD00", "usage": "Title slides, section dividers, icon grids, closing slides", "$note": "Most dark layouts use #000000 (scheme:tx1). #1D2632 (navy) used for accent fills (snip1Rect cards, title slide bg, decorative shapes)" },
          "yellow": { "bg": "#FFCD00", "text": "#1D2632", "accent": "#1D2632", "usage": "Emphasis slides, quotes, timelines, KPI displays" },
          "light":  { "bg": "#FFFFFF", "text": "#1D2632", "accent": "#FFCD00", "usage": "Content slides, charts, two-column layouts, image+text" }
        },
        "hexagonMotif": {
          "$description": "The yellow hexagon is the core visual motif in ALL Blinqx presentations.",
          "iconContainer": "Colored hexagon (B100/Y100/G100) with dark icon inside — used on dark slides",
          "decorative": "Oversized hexagon outlines (Y100 stroke) on closing slides",
          "floating": "Small solid yellow hexagons near images/quotes as visual accent",
          "timeline": "White hexagons with icons as timeline nodes on dashed connector lines",
          "kpiShape": "Chevron/pentagon-shaped cards for stat callouts"
        },
        "labelTags": {
          "$shape": "snip1Rect (prstGeom='snip1Rect' — Rectangle: Single Corner Snipped), NOT plain rectangles",
          "yellow": { "bg": "#FFCD00", "text": "#1D2632", "shape": "snip1Rect", "usage": "Section subtitles, quote attributions" },
          "black":  { "bg": "#1D2632", "text": "#FFFFFF", "shape": "snip1Rect", "usage": "Category labels, overlay captions" }
        },
        "rules": [
          "Alternate themes between consecutive slides — never repeat same background",
          "Yellow background = emphasis — use for the most important content",
          "Include hexagon motif on every 2-3 slides minimum",
          "Titles are oversized (44pt+) for visual impact",
          "Minimal text per slide — visuals and headings carry the message",
          "Charts use teal/green gradient palette, not primary blue",
          "Logo always top-right: dark variant on light/yellow, light variant on dark"
        ]
      },
      "rules": [
        "Presentations (.pptx): use Metropolis (embedded in .potx template via python-pptx). PDF/docx/xlsx: use Inter (Metropolis not embeddable)",
        "Max 3 colors per slide: text + accent + 1 status color",
        "Max 1 yellow highlight per slide/page",
        "Max weight is SemiBold (600) — never Bold (700)",
        "Use #1D2632 for body text. Dark slide backgrounds use #000000 (scheme:tx1, see presentationDesign.themes.dark)",
        "Build presentations from .potx template using python-pptx — never recreate slides from scratch"
      ]
    },

    "prototype": {
      "$description": "Use for React, HTML, CSS, Tailwind, v0, Cursor, Claude code generation.",
      "$appliesTo": ["react", "html", "css", "tailwind", "nextjs", "vue", "svelte", "v0", "cursor"],
      "typography": {
        "fontFamily": "'Metropolis UI', 'Inter', Arial, Helvetica, sans-serif",
        "$note": "Declare Metropolis UI first, Inter as system fallback"
      },
      "colors": {
        "$note": "Use the full semantic token system. Reference: colors.semantic in this file.",
        "cssVarSyntax": "var(--surface/surface-blue-default, #6DA6B9)",
        "tailwindSyntax": "bg-[var(--surface/surface-blue-default,#6da6b9)]"
      },
      "components": {
        "$note": "Load references/components.json for full component specs with Tailwind code examples."
      },
      "rules": [
        "Use Metropolis UI as primary font, Inter as fallback",
        "Use semantic CSS variable names from cssVariables section",
        "Use full palette scales — not simplified document colors",
        "Buttons must be pill-shaped (border-radius: 48px)",
        "Inputs use bottom-border only — never fully bordered boxes",
        "Every interactive element needs 5 states: enabled, hovered, focused, pressed, disabled"
      ]
    }
  },

  "forbidden": {
    "$description": "Colors and patterns that must NEVER be used.",
    "colors": [
      { "hex": "#000000", "reason": "Use #1D2632 (N100) instead of pure black" },
      { "hex": "#007776", "reason": "Blis Digital brand color — wrong brand" },
      { "hex": "#00CDB6", "reason": "Blis Digital brand color — wrong brand" }
    ],
    "patterns": [
      { "pattern": "Yellow text on white background", "reason": "1.3:1 contrast — invisible" },
      { "pattern": "White text on yellow background", "reason": "1.3:1 contrast — invisible" },
      { "pattern": "font-weight: 700 or bold", "reason": "Max weight is 600 (SemiBold)" },
      { "pattern": "Square buttons (border-radius < 48px)", "reason": "Buttons must be pill-shaped" },
      { "pattern": "Fully bordered inputs", "reason": "Inputs use bottom-border-only" }
    ]
  }
}